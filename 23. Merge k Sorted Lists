# https://leetcode.com/problems/merge-k-sorted-lists/description/
import heapq
# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def mergeKLists(self, lists: List[Optional[ListNode]]) -> Optional[ListNode]:
        res = []
        for i in lists:
            curr = i
            while curr:
                res.append(curr.val)
                curr = curr.next
        res.sort()
        
        hack = None
        tail = None
        for val in res:
            node = ListNode(val)
            if hack is None:
                hack = node
                tail = node
            else:
                tail.next = node
                tail = node
        return hack
