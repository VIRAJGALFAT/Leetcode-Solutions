#https://leetcode.com/problems/insertion-sort-list/description/

# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def insertionSortList(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if not head:
            return 
    
        curr = head
        res = []
        while curr:
            res.append(curr.val)
            curr = curr.next

        res.sort()
        hack = None
        tail = None
        for val in res:
            node = ListNode(val)
            if hack is None:
                hack = node
                tail = node
            else:
                tail.next = node
                tail = node
        return hack

        
