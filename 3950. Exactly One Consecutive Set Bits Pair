#https://leetcode.com/problems/exactly-one-consecutive-set-bits-pair/description/


class Solution:
    def consecutiveSetBits(self, n: int) -> bool:
        n = bin(n)
        n = str(n)
        n = n[2:]
        cnt = 0
        for i in range(1,len(n)):
            if n[i] == '1' and n[i-1] == '1':
                cnt += 1
            else:
                continue

        if cnt == 1:
            return True
        else:
            return False
