# https://leetcode.com/problems/sort-list/
# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def sortList(self, head: Optional[ListNode]) -> Optional[ListNode]:
        res = []
        if not head:
            return
        curr = head
        while curr:
            res.append(curr.val)
            curr = curr.next
        res.sort()
 
        hack = None
        tail = None
        for val in res:
            node = ListNode(val)
            
            if hack is None:
               hack = node
               tail = node
            else:
                tail.next = node
                tail = node
        return hack
               
