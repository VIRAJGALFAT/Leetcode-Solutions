#https://leetcode.com/problems/partition-list/description/

# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def partition(self, head: Optional[ListNode], x: int) -> Optional[ListNode]:
        if not head:
            return 
        curr = head
        less = []
        more = []
        while curr:
            if curr.val >= x:
                more.append(curr.val)
            else:
                less.append(curr.val)
            curr = curr.next
        less += more
        hack = None
        tail = None
        for val in less:
            node = ListNode(val)
            if hack is None:
                hack = node
                tail = node
            else:
                tail.next = node
                tail = node
        return hack

